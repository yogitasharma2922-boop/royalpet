{
  "name": "royalpet-server",
  "version": "0.1.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js",
    "reset-db": "knex migrate:rollback --all --knexfile knexfile.js && npm run migrate && npm run seed",
    "test": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.918.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "knex": "^2.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6",
    "winston": "^3.15.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4"
  }
}
