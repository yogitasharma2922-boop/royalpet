# Server configuration
PORT=4000

# JWT secret (use a strong random value in production)
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# CORS (comma-separated origins). Example: http://localhost:5173,https://your-app.vercel.app
CORS_ORIGINS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=info

# Uploads
UPLOAD_DIR=./uploads

# Database configuration
# For sqlite (default): leave DATABASE_URL empty and specify SQLITE_FILE
SQLITE_FILE=./data/royalpet.db
ALLOW_BULK_SYNC=true

# For postgres, set DATABASE_URL like:
# DATABASE_URL=postgresql://user:password@localhost:5432/royalpet
